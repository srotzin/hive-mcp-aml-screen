{
  "name": "hive-mcp-aml-screen",
  "version": "1.0.0",
  "description": "AML screening broker for the A2A network. Combines a daily-refreshed OFAC SDN list with on-chain heuristic flags and returns an observational risk score. Data only — Hive does not block, freeze, or settle.",
  "type": "module",
  "main": "server.js",
  "bin": {
    "hive-mcp-aml-screen": "./server.js"
  },
  "scripts": {
    "start": "node server.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "a2a",
    "ai-agent",
    "hive",
    "hive-civilization",
    "aml",
    "anti-money-laundering",
    "ofac",
    "sdn",
    "sanctions",
    "risk-scoring",
    "compliance",
    "broker",
    "observational",
    "ethers",
    "base-l2",
    "usdc",
    "real-rails"
  ],
  "author": "Steve Rotzin <steve@thehiveryiq.com> (https://www.thehiveryiq.com)",
  "license": "MIT",
  "homepage": "https://github.com/srotzin/hive-mcp-aml-screen",
  "repository": {
    "type": "git",
    "url": "https://github.com/srotzin/hive-mcp-aml-screen"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "csv-parse": "^5.5.6",
    "ethers": "^6.13.2",
    "express": "^4.19.2"
  }
}
